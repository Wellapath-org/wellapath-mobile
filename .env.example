# ──────────────────────────────────────────
# WellaPath Mobile — Environment Variables
# Copy this file to .env and fill in values
# Never commit .env to Git
# ──────────────────────────────────────────

# API
API_BASE_URL=https://api-staging.wellapath.org
API_TIMEOUT_MS=10000

# Artifacts
ARTIFACT_BASE_URL=https://d179u2ex0g66o3.cloudfront.net

# Environment
APP_ENV=staging

# Feature Flags
ENABLE_OFFLINE_MODE=true
ENABLE_FACILITY_LOCATOR=false
```

Also create a `.gitignore` in the mobile repo root:
```
.env
.dart_tool/
build/
*.g.dart
*.freezed.dart
pubspec.lock
.flutter-plugins
.flutter-plugins-dependencies